{
  "name": "bale-notifier",
  "version": "1.0.0",
  "description": "Monitor Bale messenger for new messages and calls, forward notifications to Telegram, Discord, or Slack",
  "license": "MIT",
  "keywords": [
    "bale",
    "telegram",
    "notifications",
    "discord",
    "slack",
    "puppeteer",
    "docker"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aazirani/bale-notifier.git"
  },
  "bugs": {
    "url": "https://github.com/aazirani/bale-notifier/issues"
  },
  "homepage": "https://github.com/aazirani/bale-notifier#readme",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/confirm": "^6.0.12",
    "@inquirer/input": "^5.0.12",
    "@inquirer/select": "^5.1.4",
    "inquirer": "^12.0.0",
    "node-telegram-bot-api": "^0.66.0",
    "puppeteer": "^23.0.0"
  },
  "puppeteer": {
    "skipDownload": true
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
